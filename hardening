def check_snort_installed():
    rc, _ = run_cmd("snort -V")
    return rc == 0

def check_snort_config():
    # Cek HOME_NET tidak boleh "any"
    rc1, out = run_cmd("grep -E '^ipvar HOME_NET any' /etc/snort/snort.conf")
    if rc1 == 0:
        return False
    # Test konfigurasi
    rc2, _ = run_cmd("snort -T -c /etc/snort/snort.conf 2>/dev/null")
    return rc2 == 0

def check_snort_local_rules():
    if not os.path.isfile("/etc/snort/local.rules"):
        return False
    # Baca file
    with open("/etc/snort/local.rules", "r") as f:
        content = f.read().lower()
    # Cek ada kata "port scan" dan "icmp flood" di msg
    if "port scan" not in content:
        return False
    if "icmp flood" not in content:
        return False
    # Minimal ada 2 aturan (bisa lebih)
    lines = [l.strip() for l in content.split('\n') if l.strip() and not l.strip().startswith('#')]
    # Aturan Snort biasanya diawali dengan "alert"
    rules = [l for l in lines if l.startswith('alert')]
    return len(rules) >= 2

def check_snort_daemon():
    rc, _ = run_cmd("pgrep -f 'snort.*-D'")
    return rc == 0

def check_snort_alert():
    if not os.path.isfile("/var/log/snort/alert"):
        return False
    if os.path.getsize("/var/log/snort/alert") == 0:
        return False
    with open("/var/log/snort/alert", "r") as f:
        content = f.read().lower()
    return "port scan" in content and "icmp flood" in content

