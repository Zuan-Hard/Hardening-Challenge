def check_mysql_lksuser():
    rc1, _ = run_cmd(f"{MYSQL_CMD} -e \"SELECT Db,Select_priv,Insert_priv,Update_priv,Delete_priv FROM mysql.db WHERE User='lksuser' AND Db='lks_db';\" 2>/dev/null | grep -q 'lks_db'")
