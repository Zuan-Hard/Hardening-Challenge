        elif choice == '3':
            run_scoring()
        elif choice == '0':
            print_info("Terima kasih. Sampai jumpa!")
            sys.exit(0)
        else:
            print_error("Pilihan tidak valid.")
            time.sleep(1)

# ========================
# Main dengan argparse
# ========================
def main():
    parser = argparse.ArgumentParser(description='HARDENING CHALLENGE FOR BLUE TEAM')
    parser.add_argument('--setup', action='store_true', help='Setup environment (install LAMPP + anomali)')
    parser.add_argument('--reset', action='store_true', help='Hapus flag setup')
    parser.add_argument('--score', action='store_true', help='Langsung scoring')
    parser.add_argument('--questions', action='store_true', help='Tampilkan semua soal')
    args = parser.parse_args()

    if args.reset:
        if os.path.exists(SETUP_FLAG):
            os.remove(SETUP_FLAG)
            print_success("Flag setup dihapus.")
        else:
            print_info("Tidak ada flag setup.")
        return

    if args.setup:
        setup_environment(force=True)
        return

    if args.score:
        run_scoring()
        return

    if args.questions:
        # Tampilkan semua soal
        for task_id in range(1, 6):
            print(f"\n{BOLD}{CYAN}{TASKS[task_id]['title']}{RESET}")
            for item in TASKS[task_id]['items']:
                print(f"  {item}")
        return

    # Tanpa argumen: cek setup
    if not os.path.exists(SETUP_FLAG):
        print_info("Belum ada setup environment.")
        if confirm("Lakukan setup sekarang?"):
            setup_environment(force=True)
        else:
            print_info("Anda bisa jalankan nanti dengan --setup")
            sys.exit(0)

    main_menu()

if __name__ == "__main__":
    if os.geteuid() != 0:
        print(f"{RED}Script harus dijalankan sebagai root!{RESET}")
        sys.exit(1)
    main()
