def check_ufw_default_deny():
    rc, _ = run_cmd("sudo ufw status | grep -q 'Default: deny (incoming)'")
    return rc == 0

def check_bad_ports_blocked():
    rc, _ = run_cmd("sudo ufw status | grep -E '(21|23|25)/tcp.*ALLOW IN'")
    return rc != 0

def check_http_allowed():
    rc, _ = run_cmd("sudo ufw status | grep -q '80/tcp.*ALLOW IN'")
    return rc == 0

def check_ufw_logging_low():
    rc, _ = run_cmd("sudo ufw status verbose | grep -q 'Logging: on (low)'")
    return rc == 0

def check_telnet_ftp_disabled():
    rc1, _ = run_cmd("systemctl is-active --quiet telnetd")
    rc2, _ = run_cmd("systemctl is-active --quiet vsftpd")
    return rc1 != 0 and rc2 != 0

def check_root_login_disabled():
    rc, _ = run_cmd("sudo sshd -T | grep -q 'permitrootlogin no'")
    return rc == 0

def check_maxauthtries():
    rc, out = run_cmd("sudo sshd -T | grep -E '^maxauthtries' | awk '{print $2}'")
    if rc == 0 and out.isdigit():
        return int(out) <= 3
    return False

def check_ssh_forwarding_disabled():
    checks = [
        "sudo sshd -T | grep -q 'allowagentforwarding no'",
        "sudo sshd -T | grep -q 'allowtcpforwarding no'",
        "sudo sshd -T | grep -q 'gatewayports no'",
        "sudo sshd -T | grep -q 'x11forwarding no'"
    ]
    for cmd in checks:
        rc, _ = run_cmd(cmd)
        if rc != 0:
            return False
    return True

def check_clientaliveinterval():
    rc, out = run_cmd("sudo sshd -T | grep -E '^clientaliveinterval' | awk '{print $2}'")
    if rc == 0 and out.isdigit():
        return int(out) <= 300
    return False

def check_ssh_loglevel():
    rc, _ = run_cmd("sudo sshd -T | grep -q 'loglevel VERBOSE'")
    return rc == 0

def check_ssh_keypair():
    return os.path.isdir("/root/key-pair-ssh") and any(f.endswith(".pub") for f in os.listdir("/root/key-pair-ssh"))

