def setup_environment(force=False):
    if not force and os.path.exists(SETUP_FLAG):
        print_info("Environment sudah pernah disetup. Gunakan --reset jika ingin mengulang.")
        return False

    print_header()
    print_info("Memulai persiapan environment...")
    if not confirm("Proses ini akan mengubah konfigurasi sistem. Lanjutkan?"):
        print_info("Dibatalkan.")
        return False

    # Langkah 1: download LAMPP
    print_step("Mengunduh komponen pendukung...")
    if not os.path.exists(LAMPP_INSTALLER):
        try:
            urllib.request.urlretrieve(LAMPP_URL, LAMPP_INSTALLER)
            os.chmod(LAMPP_INSTALLER, 0o755)
        except Exception as e:
            print_error(f"Gagal download: {e}")
            return False

    # Langkah 2: install LAMPP
    print_step("Mengekstrak dan memasang...")
    if not os.path.exists(LAMPP_PATH):
        ret = subprocess.run(f"{LAMPP_INSTALLER} --mode unattended --installdir {LAMPP_PATH}", shell=True).returncode
        if ret != 0:
            print_error("Instalasi gagal")
            return False

    # Langkah 3: tanam anomali (tidak dirinci)
    print_step("Menanamkan anomali sistem...")
    # Start LAMPP
    subprocess.run("sudo /opt/lampp/lampp start", shell=True)
    # Reset MySQL root password kosong
    subprocess.run("sudo /opt/lampp/bin/mysqladmin -u root password ''", shell=True)
    # Anomali MySQL
    mysql_cmd = "sudo /opt/lampp/bin/mysql -u root -e"
    subprocess.run(f'{mysql_cmd} "CREATE USER IF NOT EXISTS ''@''localhost''; GRANT ALL ON *.* TO ''@''localhost'';"', shell=True)
    subprocess.run(f'{mysql_cmd} "CREATE USER IF NOT EXISTS ''attacker''@''%'' IDENTIFIED BY ''weak''; GRANT ALL PRIVILEGES ON *.* TO ''attacker''@''%'' WITH GRANT OPTION;"', shell=True)
    subprocess.run(f'{mysql_cmd} "CREATE DATABASE IF NOT EXISTS test;"', shell=True)
    with open("/opt/lampp/etc/my.cnf", "a") as f:
        f.write("\nbind-address = 0.0.0.0\nlocal_infile = 1\n")
    subprocess.run("sudo /opt/lampp/lampp restartmysql", shell=True)
    # UFW default allow, buka port berbahaya
    subprocess.run("sudo ufw --force reset", shell=True)
    subprocess.run("sudo ufw default allow incoming", shell=True)
    for port in [21,23,3306,22]:
        subprocess.run(f"sudo ufw allow {port}/tcp", shell=True)
    subprocess.run("sudo ufw --force enable", shell=True)
    # SSH tidak aman
    sshd_config = "/etc/ssh/sshd_config"
    if os.path.exists(sshd_config):
        shutil.copy(sshd_config, f"{sshd_config}.bak")
        subprocess.run(f"sudo sed -i 's/^PermitRootLogin.*/PermitRootLogin yes/' {sshd_config}", shell=True)
        subprocess.run(f"sudo sed -i 's/^MaxAuthTries.*/MaxAuthTries 10/' {sshd_config}", shell=True)
        subprocess.run(f"sudo sed -i 's/^ClientAliveInterval.*/ClientAliveInterval 0/' {sshd_config}", shell=True)
        subprocess.run(f"sudo sed -i 's/^LogLevel.*/LogLevel INFO/' {sshd_config}", shell=True)
        subprocess.run("sudo systemctl restart ssh", shell=True)
    # Aktifkan telnet & vsftpd
    subprocess.run("sudo apt update -qq", shell=True)
    subprocess.run("sudo apt install -y telnetd vsftpd", shell=True)
    subprocess.run("sudo systemctl enable --now telnetd", shell=True)
    subprocess.run("sudo systemctl enable --now vsftpd", shell=True)
    # Hapus artefak PGP
    for f in ["public-lks.asc", "pesan.txt", "pesan.txt.gpg", "pesan.txt.sig"]:
        if os.path.exists(f):
            os.remove(f)
    # Hapus flag Snort jika ada (biar fresh)
    subprocess.run("sudo systemctl stop snort 2>/dev/null", shell=True)
    # Tandai setup selesai
    with open(SETUP_FLAG, 'w') as f:
        f.write("setup completed")
    print_success("Setup selesai. Sistem siap untuk tantangan hardening.")
    return True

