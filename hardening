def confirm(prompt):
    resp = input(f"{YELLOW}{prompt} (y/N): {RESET}").strip().lower()
    return resp == 'y'

def run_cmd(cmd):
    """Jalankan perintah shell, kembalikan (returncode, stdout)"""
    proc = subprocess.run(cmd, shell=True, text=True, capture_output=True)
    return proc.returncode, proc.stdout.strip()

