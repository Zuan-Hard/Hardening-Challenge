# Timer global (start saat script dijalankan)
start_time = time.time()

# ========================
# Fungsi bantu tampilan
# ========================
def get_elapsed():
    elapsed = time.time() - start_time
    return time.strftime("%H:%M:%S", time.gmtime(elapsed))

def get_ip():
    try:
        ip = subprocess.getoutput("ip route get 1 | awk '{print $7;exit}'").strip()
        if not ip:
            ip = "127.0.0.1"
    except:
        ip = "127.0.0.1"
    return ip

