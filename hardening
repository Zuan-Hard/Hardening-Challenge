# Menu Utama
# ========================
def main_menu():
    while True:
        os.system('clear')
        print_header()
        if os.path.exists(SETUP_FLAG):
            print(f"{GREEN}✅ STATUS: Environment terdeteksi (sudah dalam kondisi rusak){RESET}")
        else:
            print(f"{RED}❌ STATUS: Environment BELUM disetup. Pilih opsi 2 untuk memulai.{RESET}")
        print(f"\n{BOLD}📋 Pilih tindakan:{RESET}")
        print("   [1] Lihat Soal")
        print("   [2] Setup Ulang (Reset + Install ulang environment rusak)")
        print("   [3] Jalankan Scoring Otomatis")
        print("   [0] Keluar")
        choice = input(f"{CYAN}👉 Masukkan nomor [0-3]: {RESET}").strip()
        if choice == '1':
            show_questions()
        elif choice == '2':
            if confirm("Ini akan menghapus setup sebelumnya dan menginstal ulang environment. Lanjutkan?"):
                if os.path.exists(SETUP_FLAG):
                    os.remove(SETUP_FLAG)
                setup_environment(force=True)
            else:
                print_info("Dibatalkan.")
            input("Tekan Enter untuk melanjutkan...")
        elif choice == '3':
            run_scoring()
            input("Tekan Enter untuk melanjutkan...")
        elif choice == '0':
            print_info("Terima kasih.")
            sys.exit(0)
        else:
            print_error("Pilihan tidak valid.")
            time.sleep(1)

# ========================
# Main dengan Argparse
# ========================
def main():
    parser = argparse.ArgumentParser(description='HARDENING CHALLENGE FOR BLUE TEAM - LKS Cybersecurity 2026')
    parser.add_argument('--setup', action='store_true', help='Setup environment rusak (instalasi + anomali)')
    parser.add_argument('--reset', action='store_true', help='Hapus tanda setup (agar prompt muncul lagi)')
    parser.add_argument('--score', action='store_true', help='Langsung jalankan scoring tanpa menu')
    parser.add_argument('--questions', action='store_true', help='Tampilkan soal tanpa menu')
    args = parser.parse_args()

    if args.reset:
        if os.path.exists(SETUP_FLAG):
            os.remove(SETUP_FLAG)
            print_success("Flag setup dihapus. Jalankan tanpa argumen untuk memulai setup ulang.")
        else:
            print_info("Tidak ada flag setup yang ditemukan.")
        return

    if args.setup:
        setup_environment(force=True)
        return

    if args.score:
        run_scoring()
        return

    if args.questions:
        show_questions()
        return

    # Tanpa argumen: cek flag
    if not os.path.exists(SETUP_FLAG):
        print_info("Belum ada setup environment.")
        if confirm("Lakukan setup sekarang?"):
            setup_environment(force=True)
        else:
            print_info("Anda bisa menjalankan nanti dengan --setup")
            sys.exit(0)

    main_menu()

if __name__ == "__main__":
    if os.geteuid() != 0:
        print(f"{RED}Script harus dijalankan sebagai root!{RESET}")
        sys.exit(1)
    main()
