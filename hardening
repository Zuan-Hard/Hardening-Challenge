def print_info(msg):
    print(f"{CYAN}[INFO]{RESET} {msg}")

def print_success(msg):
    print(f"{GREEN}[SUCCESS]{RESET} {msg}")

def print_error(msg):
    print(f"{RED}[ERROR]{RESET} {msg}")

def print_step(msg):
    print(f"{YELLOW}[STEP]{RESET} {msg}")

def run_cmd(cmd, shell=True, capture=True):
    if shell:
        proc = subprocess.run(cmd, shell=True, text=True, capture_output=capture)
    else:
        proc = subprocess.run(cmd.split(), text=True, capture_output=capture)
    return proc.returncode, proc.stdout.strip(), proc.stderr.strip()

def confirm(prompt):
    resp = input(f"{YELLOW}{prompt} (y/N): {RESET}").strip().lower()
    return resp == 'y'

def spinner(message, duration=0.5):
    chars = ['⠋', '⠙', '⠹', '⠸', '⠼', '⠴', '⠦', '⠧', '⠇', '⠏']
    end = time.time() + duration
    i = 0
    while time.time() < end:
        sys.stdout.write(f"\r{message} {chars[i % len(chars)]}")
        sys.stdout.flush()
        time.sleep(0.1)
        i += 1
    sys.stdout.write(f"\r{message} {' ' * 10}\r")
    sys.stdout.flush()

def progress_bar(current, total, prefix=""):
    bar_len = 30
    filled = int(bar_len * current // total)
    bar = '█' * filled + '░' * (bar_len - filled)
    pct = (current / total) * 100
    sys.stdout.write(f"\r{prefix} [{bar}] {pct:.0f}%")
    sys.stdout.flush()
    if current == total:
        print()

# ========================
# Fungsi Setup Environment (Tanpa Detail)
# ========================
def setup_environment(force=False):
    if not force and os.path.exists(SETUP_FLAG):
        print_info("Environment sudah pernah disetup. Gunakan --reset jika ingin mengulang.")
        return False

    print_header()
    print_info("Memulai persiapan environment...")
    if not confirm("Proses ini akan mengubah konfigurasi sistem. Lanjutkan?"):
        print_info("Dibatalkan.")
        return False

    # Langkah 1: Download komponen
    print_step("Mengunduh komponen pendukung...")
    if not os.path.exists(LAMPP_INSTALLER):
        try:
            urllib.request.urlretrieve(LAMPP_URL, LAMPP_INSTALLER, reporthook=lambda b, bs, ts: progress_bar(b*bs, ts, "Download"))
            os.chmod(LAMPP_INSTALLER, 0o755)
            print()
        except Exception as e:
            print_error(f"Gagal download: {e}")
            return False
    else:
        print_info("Sudah ada.")

    # Langkah 2: Ekstrak/install
    print_step("Mengekstrak dan memasang...")
    if not os.path.exists(LAMPP_PATH):
        ret, _, err = run_cmd(f"{LAMPP_INSTALLER} --mode unattended --installdir {LAMPP_PATH}")
        if ret != 0:
            print_error(f"Instalasi gagal: {err}")
            return False
    print_success("Langkah 2 selesai.")

    # Langkah 3: Menanamkan anomali sistem (tidak dirinci)
    print_step("Menanamkan anomali sistem...")
    # Start LAMPP
    run_cmd("sudo /opt/lampp/lampp start")
    # Reset MySQL root password kosong
    run_cmd("sudo /opt/lampp/bin/mysqladmin -u root password ''")
    # Anomali MySQL: user anonim, attacker@%, test db, bind-address, local_infile
    mysql_cmd = "sudo /opt/lampp/bin/mysql -u root -e"
    run_cmd(f'{mysql_cmd} "CREATE USER IF NOT EXISTS ''@''localhost''; GRANT ALL ON *.* TO ''@''localhost'';"')
    run_cmd(f'{mysql_cmd} "CREATE USER IF NOT EXISTS ''attacker''@''%'' IDENTIFIED BY ''weak''; GRANT ALL PRIVILEGES ON *.* TO ''attacker''@''%'' WITH GRANT OPTION;"')
    run_cmd(f'{mysql_cmd} "CREATE DATABASE IF NOT EXISTS test;"')
    with open("/opt/lampp/etc/my.cnf", "a") as f:
        f.write("\nbind-address = 0.0.0.0\nlocal_infile = 1\n")
    run_cmd("sudo /opt/lampp/lampp restartmysql")
    # UFW default allow, buka port berbahaya
    run_cmd("sudo ufw --force reset")
    run_cmd("sudo ufw default allow incoming")
    for port in [21,23,3306,22]:
        run_cmd(f"sudo ufw allow {port}/tcp")
    run_cmd("sudo ufw --force enable")
    # SSH tidak aman
    sshd_config = "/etc/ssh/sshd_config"
    if os.path.exists(sshd_config):
        shutil.copy(sshd_config, f"{sshd_config}.bak")
        run_cmd(f"sudo sed -i 's/^PermitRootLogin.*/PermitRootLogin yes/' {sshd_config}")
        run_cmd(f"sudo sed -i 's/^MaxAuthTries.*/MaxAuthTries 10/' {sshd_config}")
        run_cmd(f"sudo sed -i 's/^ClientAliveInterval.*/ClientAliveInterval 0/' {sshd_config}")
        run_cmd(f"sudo sed -i 's/^LogLevel.*/LogLevel INFO/' {sshd_config}")
        run_cmd("sudo systemctl restart ssh")
    # Aktifkan telnet & ftp
    run_cmd("sudo apt update -qq")
    run_cmd("sudo apt install -y telnetd vsftpd")
    run_cmd("sudo systemctl enable --now telnetd vsftpd")
    # Hapus artefak PGP
    for f in ["public-lks.asc", "pesan.txt", "pesan.txt.gpg", "pesan.txt.sig"]:
        if os.path.exists(f):
            os.remove(f)
    # Spinner simulasi agar terlihat ada proses
    spinner("Menanamkan anomali", duration=2)
    print_success("Langkah 3 selesai.")

    # Langkah 4: Menyelesaikan persiapan
    print_step("Menyelesaikan persiapan...")
    with open(SETUP_FLAG, 'w') as f:
        f.write("setup completed")
    spinner("Finalisasi", duration=1)
    print_success("Setup selesai. Sistem siap untuk tantangan hardening.")
    return True

